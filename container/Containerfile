FROM docker.io/python:3.12-slim

LABEL description="k8labs Ansible runner — community.crypto, community.general"

RUN apt-get update -qq \
 && apt-get install -y -qq --no-install-recommends openssh-client sshpass ca-certificates curl gnupg \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.32/deb/Release.key | gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.32/deb/ /" > /etc/apt/sources.list.d/kubernetes.list \
 && apt-get update -qq \
 && apt-get install -y -qq --no-install-recommends kubectl \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
        ansible-core==2.18.3 \
        ansible-runner==2.4.0 \
        jmespath \
  && ansible-galaxy collection install \
        community.crypto \
        community.general \
  && rm -rf /root/.cache

WORKDIR /workspace
# No fixed entrypoint — caller specifies ansible, ansible-playbook, or ansible-galaxy
ENTRYPOINT []
